<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="MuaythaiApp.ClubsWindow"
    Width="980"
    Height="620"
    Background="White"
    Title="Clubs">

<Grid>
<Grid IsHitTestVisible="False"
      Opacity="0.06"
      HorizontalAlignment="Center"
      VerticalAlignment="Center">
    <Image Source="avares://MuaythaiApp/PZMT.png"
           Width="300"
           Height="300"
           Stretch="Uniform"/>
</Grid>

<Grid RowDefinitions="Auto,Auto,Auto,*" Margin="12" RowSpacing="12">

<TextBlock
    Grid.Row="0"
    Text="Clubs"
    FontSize="22"
    FontWeight="Bold"/>

<Grid
    Grid.Row="1"
    ColumnDefinitions="*,*,*,*"
    RowDefinitions="Auto,Auto,Auto"
    ColumnSpacing="10"
    RowSpacing="10">

<StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
    <TextBlock Text="Club Name"/>
    <TextBox
        x:Name="ClubNameBox"
        Watermark="Club name"/>
</StackPanel>

<StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
    <TextBlock Text="Coach"/>
    <TextBox
        x:Name="CoachBox"
        Watermark="Coach name"/>
</StackPanel>

<StackPanel Grid.Row="0" Grid.Column="2" Spacing="4">
    <TextBlock Text="City"/>
    <TextBox
        x:Name="CityBox"
        Watermark="City"/>
</StackPanel>

<StackPanel Grid.Row="0" Grid.Column="3" Spacing="4">
    <TextBlock Text="Country"/>
    <TextBox
        x:Name="CountryBox"
        Watermark="Country"/>
</StackPanel>

<StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="10">
    <Button
        Content="Add Club"
        Click="AddClick"/>
    <Button
        Content="Update Club"
        Click="UpdateClick"/>
    <Button
        Content="Delete Club"
        Click="DeleteClick"/>
    <Button
        Content="Clear"
        Click="ClearClick"/>
    <TextBlock x:Name="ClubStatusText"
               VerticalAlignment="Center"/>
</StackPanel>

<StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="4" Orientation="Horizontal" Spacing="10">
    <StackPanel Spacing="4">
        <TextBlock Text="Search"/>
        <TextBox x:Name="SearchBox"
                 Width="260"
                 Watermark="Club, coach, city or country"
                 TextChanged="SearchChanged"/>
    </StackPanel>

    <TextBlock x:Name="ListInfoText"
               VerticalAlignment="Bottom"/>
</StackPanel>

</Grid>

<TextBlock
    Grid.Row="2"
    Text="Existing Clubs"
    FontSize="16"
    FontWeight="Bold"/>

<Border
    Grid.Row="3"
    BorderBrush="#444"
    BorderThickness="1"
    CornerRadius="8"
    Padding="8">

    <Grid RowDefinitions="Auto,*" RowSpacing="6">

        <Border Grid.Row="0"
                Background="#1F1F1F"
                Padding="10"
                CornerRadius="6">
            <Grid ColumnDefinitions="50,200,200,160,*"
                  ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="Id" FontWeight="Bold" Foreground="White"/>
                <TextBlock Grid.Column="1" Text="Club Name" FontWeight="Bold" Foreground="White"/>
                <TextBlock Grid.Column="2" Text="Coach" FontWeight="Bold" Foreground="White"/>
                <TextBlock Grid.Column="3" Text="City" FontWeight="Bold" Foreground="White"/>
                <TextBlock Grid.Column="4" Text="Country" FontWeight="Bold" Foreground="White"/>
            </Grid>
        </Border>

        <ListBox Grid.Row="1"
                 x:Name="ClubsList"
                 SelectionChanged="ClubSelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border Padding="10" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="50,200,200,160,*"
                              ColumnSpacing="10">
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Id}"
                                       FontWeight="Bold"/>
                            <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                            <TextBlock Grid.Column="2" Text="{Binding Coach}"/>
                            <TextBlock Grid.Column="3" Text="{Binding City}"/>
                            <TextBlock Grid.Column="4" Text="{Binding Country}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

    </Grid>

</Border>

</Grid>
</Grid>

</Window>
