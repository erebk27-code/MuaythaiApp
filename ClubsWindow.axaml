<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="MuaythaiApp.ClubsWindow"
    Width="1320"
    Height="760"
    Background="White"
    Title="Club Information">

<Grid>
<Grid IsHitTestVisible="False"
      Opacity="0.06"
      HorizontalAlignment="Center"
      VerticalAlignment="Center">
    <Image Source="avares://MuaythaiApp/PZMT.png"
           Width="300"
           Height="300"
           Stretch="Uniform"/>
</Grid>

<Grid RowDefinitions="Auto,Auto,Auto,*" Margin="12" RowSpacing="12">

<TextBlock
    Grid.Row="0"
    Text="Club Information"
    FontSize="22"
    FontWeight="Bold"/>

<Border Grid.Row="1"
        BorderBrush="#D3D3D3"
        BorderThickness="1"
        CornerRadius="8"
        Padding="12">
<Grid
    ColumnDefinitions="*,*,*,*,180"
    RowDefinitions="Auto,Auto,Auto,Auto"
    ColumnSpacing="10"
    RowSpacing="10">

<TextBlock Grid.Row="0"
           Grid.Column="0"
           Grid.ColumnSpan="5"
           Text="Club Details"
           FontSize="16"
           FontWeight="Bold"/>

<StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
    <TextBlock Text="Club Name"/>
    <TextBox
        x:Name="ClubNameBox"
        Watermark="Club name"/>
</StackPanel>

<StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
    <TextBlock Text="Coach Name"/>
    <TextBox
        x:Name="CoachBox"
        Watermark="Coach name"/>
</StackPanel>

<StackPanel Grid.Row="1" Grid.Column="2" Spacing="4">
    <TextBlock Text="Club City"/>
    <TextBox
        x:Name="CityBox"
        Watermark="City"/>
</StackPanel>

<StackPanel Grid.Row="1" Grid.Column="3" Spacing="4">
    <TextBlock Text="Country"/>
    <TextBox
        x:Name="CountryBox"
        Watermark="Country"/>
</StackPanel>

<StackPanel Grid.Row="1" Grid.Column="4" Spacing="4">
    <TextBlock Text="Athlete Count"/>
    <TextBox x:Name="AthleteCountBox"
             Watermark="0"/>
</StackPanel>

<StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" Spacing="10">
    <Button
        Content="Add Club"
        Click="AddClick"/>
    <Button
        Content="Update Club"
        Click="UpdateClick"/>
    <Button
        Content="Delete Club"
        Click="DeleteClick"/>
    <Button
        Content="Clear"
        Click="ClearClick"/>
    <TextBlock x:Name="ClubStatusText"
               VerticalAlignment="Center"/>
</StackPanel>

<StackPanel Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="5" Orientation="Horizontal" Spacing="10">
    <StackPanel Spacing="4">
        <TextBlock Text="Search"/>
        <TextBox x:Name="SearchBox"
                 Width="260"
                 Watermark="Club, coach, city or country"
                 TextChanged="SearchChanged"/>
    </StackPanel>

    <TextBlock x:Name="ListInfoText"
               VerticalAlignment="Bottom"/>
</StackPanel>

</Grid>
</Border>

<TextBlock
    Grid.Row="2"
    Text="Existing Clubs"
    FontSize="16"
    FontWeight="Bold"/>

<Grid Grid.Row="3" ColumnDefinitions="1.1*,1*" ColumnSpacing="12">
    <Border Grid.Column="0"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8">

        <Grid RowDefinitions="Auto,*" RowSpacing="6">

            <Border Grid.Row="0"
                    Background="#1F1F1F"
                    Padding="10"
                    CornerRadius="6">
                <Grid ColumnDefinitions="50,180,180,140,120,*"
                      ColumnSpacing="10">
                    <TextBlock Grid.Column="0" Text="Id" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="1" Text="Club Name" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="2" Text="Coach" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="3" Text="City" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="4" Text="Country" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="5" Text="Athletes" FontWeight="Bold" Foreground="White"/>
                </Grid>
            </Border>

            <ListBox Grid.Row="1"
                     x:Name="ClubsList"
                     SelectionChanged="ClubSelectionChanged">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="10" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                            <Grid ColumnDefinitions="50,180,180,140,120,*"
                                  ColumnSpacing="10">
                                <TextBlock Grid.Column="0"
                                           Text="{Binding Id}"
                                           FontWeight="Bold"/>
                                <TextBlock Grid.Column="1" Text="{Binding Name}"/>
                                <TextBlock Grid.Column="2" Text="{Binding Coach}"/>
                                <TextBlock Grid.Column="3" Text="{Binding City}"/>
                                <TextBlock Grid.Column="4" Text="{Binding Country}"/>
                                <TextBlock Grid.Column="5" Text="{Binding AthleteCount}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>

    </Border>

    <Border Grid.Column="1"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="8"
            Padding="8">
        <Grid RowDefinitions="Auto,Auto,*" RowSpacing="8">
            <TextBlock Text="Club Athlete List"
                       FontSize="16"
                       FontWeight="Bold"/>

            <TextBlock Grid.Row="1"
                       x:Name="ClubAthletesSummaryText"
                       Foreground="#444"
                       Text="Select a club to see athlete details."/>

            <Grid Grid.Row="2" RowDefinitions="Auto,*" RowSpacing="6">
                <Border Grid.Row="0"
                        Background="#1F1F1F"
                        Padding="10"
                        CornerRadius="6">
                    <Grid ColumnDefinitions="170,50,80,130,*"
                          ColumnSpacing="10">
                        <TextBlock Grid.Column="0" Text="Athlete" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Grid.Column="1" Text="Age" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Grid.Column="2" Text="Gender" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Grid.Column="3" Text="Category" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Grid.Column="4" Text="Weight" FontWeight="Bold" Foreground="White"/>
                    </Grid>
                </Border>

                <ListBox Grid.Row="1"
                         x:Name="ClubAthletesList">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" BorderBrush="#2A2A2A" BorderThickness="0,0,0,1">
                                <Grid ColumnDefinitions="170,50,80,130,*"
                                      ColumnSpacing="10">
                                    <TextBlock Grid.Column="0" Text="{Binding FullName}" FontWeight="SemiBold"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Age}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Gender}"/>
                                    <TextBlock Grid.Column="3" Text="{Binding AgeCategory}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding WeightClassDisplay}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Grid>
    </Border>
</Grid>

</Grid>
</Grid>

</Window>
