<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="MuaythaiApp.ReportsWindow"
    Width="1180"
    Height="760"
    Background="White"
    Title="Reports">

<Grid>
<Grid IsHitTestVisible="False"
      Opacity="0.05"
      HorizontalAlignment="Center"
      VerticalAlignment="Center">
    <Image Source="avares://MuaythaiApp/PZMT.png"
           Width="340"
           Height="340"
           Stretch="Uniform"/>
</Grid>

<Grid Margin="12" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">
    <TextBlock Grid.Row="0"
               x:Name="ReportsTitleText"
               Text="Reports"
               FontSize="22"
               FontWeight="Bold"/>

    <WrapPanel Grid.Row="1"
               Orientation="Horizontal">
        <StackPanel Spacing="4">
            <TextBlock x:Name="TournamentTitleLabelText" Text="Tournament Title"/>
            <TextBox x:Name="TournamentTitleBox"
                     Width="260"
                     TextChanged="TournamentTitleChanged"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock x:Name="ReportTypeLabelText" Text="Report Type"/>
            <ComboBox x:Name="ReportTypeCombo"
                      Width="220"
                      SelectionChanged="ReportChanged"/>
        </StackPanel>

        <StackPanel x:Name="ReportDayPanel" Spacing="4">
            <TextBlock x:Name="ReportDayLabelText" Text="Day"/>
            <ComboBox x:Name="ReportDayCombo"
                      Width="110"
                      SelectionChanged="ReportChanged"/>
        </StackPanel>

        <StackPanel x:Name="ReportDatePanel" Spacing="4">
            <TextBlock x:Name="ReportDateLabelText" Text="Date"/>
            <TextBox x:Name="ReportDateBox"
                     Width="120"
                     TextChanged="TournamentTitleChanged"/>
        </StackPanel>

        <StackPanel x:Name="RingPanel" Spacing="4">
            <TextBlock x:Name="RingLabelText" Text="Ring"/>
            <ComboBox x:Name="RingCombo"
                      Width="120"
                      SelectionChanged="ReportChanged"/>
        </StackPanel>

        <Button x:Name="RefreshButton" Content="Refresh"
                VerticalAlignment="Bottom"
                Click="RefreshClick"/>

        <Button x:Name="ExportCsvButton" Content="Export CSV"
                VerticalAlignment="Bottom"
                Click="ExportCsvClick"/>

        <Button x:Name="ExportPdfButton" Content="Export PDF"
                VerticalAlignment="Bottom"
                Click="ExportPdfClick"/>

        <Button x:Name="PrintButton" Content="Print"
                VerticalAlignment="Bottom"
                Click="PrintClick"/>
    </WrapPanel>

    <TextBlock Grid.Row="2"
               x:Name="SummaryText"
               Foreground="#444"/>

    <Border Grid.Row="3"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="8"
            Padding="10">
        <Grid>
            <TextBox x:Name="PreviewTextBox"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="NoWrap"
                     FontFamily="Cascadia Mono, Consolas, Menlo, monospace"
                     FontSize="14"/>

            <ScrollViewer x:Name="BracketScrollViewer"
                          IsVisible="False"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="BracketHostPanel"
                            Spacing="12"/>
            </ScrollViewer>

            <ScrollViewer x:Name="ScheduleScrollViewer"
                          IsVisible="False"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ScheduleHostPanel"
                            Spacing="12"/>
            </ScrollViewer>
        </Grid>
    </Border>
</Grid>
</Grid>

</Window>
