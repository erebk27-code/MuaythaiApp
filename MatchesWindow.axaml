<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="MuaythaiApp.MatchesWindow"
    Width="980"
    Height="620"
    Background="White"
    Title="Matches">

<Grid>
<Grid IsHitTestVisible="False"
      Opacity="0.06"
      HorizontalAlignment="Center"
      VerticalAlignment="Center">
    <Image Source="avares://MuaythaiApp/PZMT.png"
           Width="300"
           Height="300"
           Stretch="Uniform"/>
</Grid>

<Grid Margin="12" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="12">

<TextBlock x:Name="MatchesTitleText"
           Text="Matches"
           Grid.Row="0"
           FontSize="20"/>

<StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="10">

<TextBlock x:Name="DayLabelText" Text="Day"/>

<ComboBox
    x:Name="DayFilterCombo"
    Width="110"
    SelectionChanged="DayChanged"/>

<TextBlock x:Name="RingLabelText" Text="Ring"/>

<ComboBox
    x:Name="RingFilterCombo"
    Width="120"
    SelectionChanged="RingChanged"/>

<TextBlock x:Name="JudgesLabelText" Text="Judges"/>

<ComboBox
    x:Name="JudgesCombo"
    Width="100"/>

<Button
    x:Name="AutoMatchButton"
    Content="Auto Match Maker"
    Click="AutoMatchClick"/>

<Button
    x:Name="DistributeRingsButton"
    Content="Distribute Rings"
    Click="DistributeRingsClick"/>

<Button
    x:Name="ScoreButton"
    Content="Score"
    Click="ScoreClick"/>

</StackPanel>

<TextBlock Grid.Row="2"
           x:Name="MatchesSummaryText"
           Foreground="#444"/>

<Border Grid.Row="3"
        BorderBrush="#444"
        BorderThickness="1"
        CornerRadius="8"
        Padding="8">

    <Grid RowDefinitions="Auto,*" RowSpacing="6">

        <Border Grid.Row="0"
                Background="#1F1F1F"
                Padding="10"
                CornerRadius="6">
            <Grid ColumnDefinitions="80,100,180,180,120,120,*,90"
                  ColumnSpacing="10">
                <TextBlock x:Name="BoutHeaderText" Grid.Column="0" Text="Bout" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="RingHeaderText" Grid.Column="1" Text="Ring" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="RedHeaderText" Grid.Column="2" Text="Red" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="BlueHeaderText" Grid.Column="3" Text="Blue" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="CategoryHeaderText" Grid.Column="4" Text="Category" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="WeightHeaderText" Grid.Column="5" Text="Weight" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="GenderHeaderText" Grid.Column="6" Text="Gender" FontWeight="Bold" Foreground="White"/>
                <TextBlock Grid.Column="7" Text="Score" FontWeight="Bold" Foreground="White"/>
            </Grid>
        </Border>

        <ListBox
            Grid.Row="1"
            x:Name="MatchesGrid">

        <ListBox.ItemTemplate>

        <DataTemplate>

        <Border Padding="10"
                BorderBrush="#2A2A2A"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="80,100,180,180,120,120,*,90"
                  ColumnSpacing="10">
                <TextBlock Grid.Column="0" Text="{Binding OrderNo}" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="{Binding RingName}"/>
                <TextBlock Grid.Column="2" Text="{Binding Fighter1Name}"/>
                <TextBlock Grid.Column="3" Text="{Binding Fighter2Name}"/>
                <TextBlock Grid.Column="4" Text="{Binding AgeCategory}"/>
                <TextBlock Grid.Column="5" Text="{Binding WeightCategory}"/>
                <TextBlock Grid.Column="6" Text="{Binding Gender}"/>
                <Button Grid.Column="7"
                        Content="Score"
                        Click="ScoreRowClick"/>
            </Grid>
        </Border>

        </DataTemplate>

        </ListBox.ItemTemplate>

        </ListBox>

    </Grid>

</Border>

</Grid>
</Grid>

</Window>
