<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="MuaythaiApp.ChangePasswordsWindow"
    Width="470"
    Height="520"
    CanResize="False"
    Background="White"
    Title="Change Passwords">

    <Border Margin="20"
            Padding="20"
            CornerRadius="14"
            Background="#F8F8F8"
            BorderBrush="#D6D6D6"
            BorderThickness="1">
        <StackPanel Spacing="12">
            <TextBlock Text="Change Passwords"
                       FontSize="24"
                       FontWeight="Bold"/>

            <TextBlock Text="Leave any new password empty if you do not want to change it."
                       Foreground="#555555"
                       TextWrapping="Wrap"/>

            <StackPanel Spacing="4">
                <TextBlock Text="Current Administrator Password"/>
                <TextBox x:Name="CurrentAdminPasswordBox"
                         PasswordChar="*"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="New Administrator Password"/>
                <TextBox x:Name="NewAdminPasswordBox"
                         PasswordChar="*"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Confirm Administrator Password"/>
                <TextBox x:Name="ConfirmAdminPasswordBox"
                         PasswordChar="*"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="New User Password"/>
                <TextBox x:Name="NewUserPasswordBox"
                         PasswordChar="*"/>
            </StackPanel>

            <StackPanel Spacing="4">
                <TextBlock Text="Confirm User Password"/>
                <TextBox x:Name="ConfirmUserPasswordBox"
                         PasswordChar="*"/>
            </StackPanel>

            <Button Content="Save Passwords"
                    Click="SaveClick"/>

            <TextBlock x:Name="StatusText"
                       TextWrapping="Wrap"/>
        </StackPanel>
    </Border>
</Window>
