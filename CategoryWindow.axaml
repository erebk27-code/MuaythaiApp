<Window
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Class="MuaythaiApp.CategoryWindow"
    Width="1100"
    Height="700"
    Background="White"
    Title="Category Management">

<Grid>
<Grid IsHitTestVisible="False"
      Opacity="0.06"
      HorizontalAlignment="Center"
      VerticalAlignment="Center">
    <Image Source="avares://MuaythaiApp/PZMT.png"
           Width="300"
           Height="300"
           Stretch="Uniform"/>
</Grid>

<Grid RowDefinitions="Auto,Auto,*" Margin="12" RowSpacing="12">

    <TextBlock
        Grid.Row="0"
        Text="Category Management"
        FontSize="22"
        FontWeight="Bold"/>

    <StackPanel
        Grid.Row="1"
        Orientation="Horizontal"
        Spacing="12">

        <StackPanel Spacing="4">
            <TextBlock Text="Division"/>
            <ComboBox x:Name="DivisionCombo" Width="150" SelectionChanged="FilterChanged"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Gender"/>
            <ComboBox x:Name="GenderCombo" Width="150" SelectionChanged="FilterChanged"/>
        </StackPanel>

        <StackPanel Spacing="4">
            <TextBlock Text="Info"/>
            <TextBlock x:Name="SummaryText" VerticalAlignment="Center"/>
        </StackPanel>

        <Button Content="Save Active Categories"
                VerticalAlignment="Bottom"
                Click="SaveActiveCategoriesClick"/>

    </StackPanel>

    <Border
        Grid.Row="2"
        BorderBrush="#444"
        BorderThickness="1"
        CornerRadius="8"
        Padding="8">

        <Grid RowDefinitions="Auto,*" RowSpacing="6">

            <Border Grid.Row="0"
                    Background="#1F1F1F"
                    Padding="10"
                    CornerRadius="6">
                <Grid ColumnDefinitions="80,220,110,90,120,120,90,80,*"
                      ColumnSpacing="10">
                    <TextBlock Grid.Column="0" Text="Active" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="1" Text="Age Category" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="2" Text="Division" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="3" Text="Gender" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="4" Text="Age Range" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="5" Text="Weight Class" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="6" Text="Rounds" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="7" Text="Break" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Grid.Column="8" Text="Sort" FontWeight="Bold" Foreground="White"/>
                </Grid>
            </Border>

            <ListBox Grid.Row="1" x:Name="CategoryList">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="80,220,110,90,120,120,90,80,*" Margin="0,2">
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsActive, Mode=TwoWay}"
                                      Checked="ActiveCategoryChanged"
                                      Unchecked="ActiveCategoryChanged"/>
                            <TextBlock Grid.Column="1" Text="{Binding DivisionWithAgeDisplay}" FontWeight="Bold"/>
                            <TextBlock Grid.Column="2" Text="{Binding Division}"/>
                            <TextBlock Grid.Column="3" Text="{Binding Gender}"/>
                            <TextBlock Grid.Column="4" Text="{Binding AgeRange}"/>
                            <TextBlock Grid.Column="5" Text="{Binding CategoryDisplay}"/>
                            <TextBlock Grid.Column="6" Text="{Binding RoundInfo}"/>
                            <TextBlock Grid.Column="7" Text="{Binding BreakInfo}"/>
                            <TextBlock Grid.Column="8" Text="{Binding SortOrder}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

        </Grid>

    </Border>

</Grid>
</Grid>

</Window>
